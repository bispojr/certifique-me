{
  "name": "certifique-me",
  "description": "Sistema de gestão e emissão de certificados digitais para eventos.",
  "author": "Esdras L. Bispo Jr. <esdraspiano@gmail.com>",
  "version": "0.0.0",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "scripts": {
    "start": "node ./bin/www",
    "test": "jest --runInBand --detectOpenHandles",
    "test:watch": "jest --watch",
    "test:coverage": "jest --runInBand --coverage",
    "test:models": "jest tests/models",
    "test:routes": "jest tests/routes",
    "test:docker": "docker-compose -f docker-compose.test.yml up -d && sleep 5 && npm test",
    "test:ci": "jest --runInBand --detectOpenHandles",
    "lint": "eslint src/** --fix",
    "format": "prettier --write .",
    "check": "npm run lint && npm run format && npm run test:ci",
    "check:docker": "docker-compose -f docker-compose.test.yml exec -T app_test sh -c 'npm run lint && npm run format && npm test'",
    "check:docker:coverage": "docker-compose -f docker-compose.test.yml exec -T app_test sh -c 'npm run lint && npm run format && npm run test:coverage'",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1041.0",
    "@aws-sdk/lib-storage": "^3.1041.0",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "connect-flash": "^0.1.1",
    "cookie-parser": "~1.4.4",
    "debug": "~2.6.9",
    "dotenv": "^17.3.1",
    "express": "^4.22.1",
    "express-handlebars": "^8.0.6",
    "express-rate-limit": "^8.3.1",
    "express-session": "^1.19.0",
    "hbs": "^4.2.0",
    "http-errors": "~1.6.3",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "pdfkit": "^0.18.0",
    "pg": "^8.20.0",
    "sequelize": "^6.37.7",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "cheerio": "^1.2.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^30.2.0",
    "jsdom": "^29.0.1",
    "node-mocks-http": "^1.17.2",
    "prettier": "^3.8.1",
    "sequelize-cli": "^6.6.5",
    "sqlite3": "^6.0.1",
    "supertest": "^7.2.2",
    "zod": "^3.22.2"
  }
}
