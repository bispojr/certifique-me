{
  "name": "certifique-me",
  "description": "Sistema de gestão e emissão de certificados digitais para eventos.",
  "author": "Esdras L. Bispo Jr. <esdraspiano@gmail.com>",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "start": "node ./bin/www",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:models": "jest tests/models",
    "test:routes": "jest tests/routes",
    "test:docker": "docker-compose -f docker-compose.test.yml up -d && sleep 5 && npm test",
    "test:ci": "jest --runInBand --forceExit",
    "lint": "eslint src/**",
    "format": "prettier --write .",
    "check": "npm run format && npm run lint && npm run test:ci"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cookie-parser": "~1.4.4",
    "debug": "~2.6.9",
    "dotenv": "^17.3.1",
    "express": "^4.22.1",
    "hbs": "^4.2.0",
    "http-errors": "~1.6.3",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "pg": "^8.20.0",
    "sequelize": "^6.37.7",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "eslint": "^10.0.3",
    "jest": "^30.2.0",
    "prettier": "^3.8.1",
    "sequelize-cli": "^6.6.5",
    "sqlite3": "^6.0.1",
    "supertest": "^7.2.2",
    "zod": "^3.22.2"
  }
}
