<h2>{{title}}</h2>
<div class='row mt-3'>
  <div class='col-md-6'>
    <form method='POST' action='{{action}}'>
      <div class='mb-3'>
        <label for='nome' class='form-label'>
          Nome do evento
          <span class='text-danger'>*</span>
        </label>
        <input
          type='text'
          class='form-control'
          name='nome'
          id='nome'
          value='{{evento.nome}}'
          required
        />
      </div>
      <div class='mb-3'>
        <label for='codigo_base' class='form-label'>
          Código base (3 letras)
          <span class='text-danger'>*</span>
        </label>
        <input
          type='text'
          class='form-control'
          name='codigo_base'
          id='codigo_base'
          value='{{evento.codigo_base}}'
          required
          pattern='[A-Za-z]{3}'
          maxlength='3'
          title='Exatamente 3 letras sem números ou símbolos'
        />
      </div>
      <div class='mb-3'>
        <label for='ano' class='form-label'>
          Ano
          <span class='text-danger'>*</span>
        </label>
        <input
          type='number'
          class='form-control'
          name='ano'
          id='ano'
          value='{{evento.ano}}'
          required
          min='2000'
          max='2100'
        />
      </div>
      <button type='submit' class='btn btn-primary'>Salvar</button>
      <a href='/admin/eventos' class='btn btn-secondary ms-2'>Cancelar</a>
    </form>
  </div>
</div>