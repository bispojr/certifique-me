

<div data-testid="admin-dashboard-root">
<!-- Certificação -->
<h5 class="mt-4 mb-3 text-muted">
  <i class="fa-solid {{resourceMeta.grupos.certificacao.icon}} me-2 text-success"></i>
  {{resourceMeta.grupos.certificacao.label}}
</h5>
<div class="row g-4">
  <div class="col-12 col-sm-6 col-xl-4">
    <a href="/admin/certificados" class="text-decoration-none">
      <div class="card dashboard-card bg-soft-info h-100">
        <div class="card-body d-flex justify-content-between align-items-center">
          <div>
            <div class="card-label">Certificados{{#if usuario.isGestor}} (seus eventos){{/if}}</div>
            <div class="card-value text-info">{{totalCertificados}}</div>
          </div>
          <i class="fa-solid {{resourceMeta.certificados.icon}} card-icon text-info"></i>
        </div>
      </div>
    </a>
  </div>
  {{#if (or usuario.isAdmin usuario.isGestor)}}
  <div class="col-12 col-sm-6 col-xl-4">
    <a href="/admin/tipos-certificados" class="text-decoration-none">
      <div class="card dashboard-card bg-soft-success h-100">
        <div class="card-body d-flex justify-content-between align-items-center">
          <div>
            <div class="card-label">Tipos</div>
            <div class="card-value text-success">{{totalTipos}}</div>
          </div>
          <i class="fa-solid {{resourceMeta.tiposCertificados.icon}} card-icon text-success"></i>
        </div>
      </div>
    </a>
  </div>
  {{/if}}
  <div class="col-12 col-sm-6 col-xl-4">
    <a href="/admin/certificados?status=pendente" class="text-decoration-none">
      <div class="card dashboard-card bg-soft-warning h-100">
        <div class="card-body d-flex justify-content-between align-items-center">
          <div>
            <div class="card-label">Pendentes</div>
            <div class="card-value text-warning">{{totalCertificadosPendentes}}</div>
          </div>
          <i class="fa-solid fa-clock card-icon text-warning"></i>
        </div>
      </div>
    </a>
  </div>
</div>

<!-- Gestão de eventos -->
<h5 class="mt-5 mb-3 text-muted">
  <i class="fa-solid {{resourceMeta.grupos.eventos.icon}} me-2 text-primary"></i>
  {{resourceMeta.grupos.eventos.label}}
</h5>
<div class="row g-4">
  <div class="col-12 col-sm-6 col-xl-4">
    <a href="/admin/eventos" class="text-decoration-none">
      <div class="card dashboard-card bg-soft-primary h-100">
        <div class="card-body d-flex justify-content-between align-items-center">
          <div>
            <div class="card-label">Eventos{{#if usuario.isGestor}} (seus eventos){{/if}}</div>
            <div class="card-value text-primary">{{totalEventos}}</div>
          </div>
          <i class="fa-solid {{resourceMeta.eventos.icon}} card-icon text-primary"></i>
        </div>
      </div>
    </a>
  </div>
  <div class="col-12 col-sm-6 col-xl-4">
    <a href="/admin/participantes" class="text-decoration-none">
      <div class="card dashboard-card bg-soft-warning h-100">
        <div class="card-body d-flex justify-content-between align-items-center">
          <div>
            <div class="card-label">Participantes{{#if usuario.isGestor}} (seus eventos){{/if}}</div>
            <div class="card-value text-warning">{{totalParticipantes}}</div>
          </div>
          <i class="fa-solid {{resourceMeta.participantes.icon}} card-icon text-warning"></i>
        </div>
      </div>
    </a>
  </div>
</div>

<!-- Administração -->
<h5 class="mt-5 mb-3 text-muted">
  <i class="fa-solid {{resourceMeta.grupos.administracao.icon}} me-2 text-danger"></i>
  {{resourceMeta.grupos.administracao.label}}
</h5>
<div class="row g-4">
  {{#if usuario.isAdmin}}
  <div class="col-12 col-sm-6 col-xl-4">
    <a href="/admin/usuarios" class="text-decoration-none">
      <div class="card dashboard-card bg-soft-danger h-100">
        <div class="card-body d-flex justify-content-between align-items-center">
          <div>
            <div class="card-label">Usuários</div>
            <div class="card-value text-danger">{{totalUsuarios}}</div>
          </div>
          <i class="fa-solid {{resourceMeta.usuarios.icon}} card-icon text-danger"></i>
        </div>
      </div>
    </a>
  </div>
  {{/if}}
</div>