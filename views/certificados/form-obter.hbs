<div class='row justify-content-center mt-5'>
  <div class='col-md-6'>
    <h2>Obter meus certificados</h2>
    {{#if mensagem}}
      <div class='alert alert-danger'>{{mensagem}}</div>
    {{/if}}
    <form method='GET' action='/public/certificados'>
      <div class='mb-3'>
        <label for='email' class='form-label'>E-mail</label>
        <input
          type='email'
          class='form-control'
          id='email'
          name='email'
          required
          placeholder='Digite seu e-mail cadastrado'
        />
      </div>
      <button type='submit' class='btn btn-primary'>Buscar certificados</button>
    </form>
    <a href='/public/pagina/opcoes' class='btn btn-link mt-3'>← Voltar</a>
  </div>
</div>