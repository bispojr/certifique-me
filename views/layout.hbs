<html lang='pt-BR'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <title>{{title}} | Certifique-me</title>
    <link
      rel='stylesheet'
      href='https://cdn.jsdelivr.net/npm/bootswatch@5.3.8/dist/brite/bootstrap.min.css'
    />
  </head>
  <body>
    <nav class='navbar navbar-expand-lg navbar-light bg-primary'>
      <div class='container'>
        <a class='navbar-brand text-black' href='/'>Certifique-me</a>
        <div class='navbar-nav ms-auto'>
          <a class='nav-link text-black' href='/certificados'>Meus Certificados</a>
          <a
            class='nav-link text-black'
            href='/certificados/validar'
          >Validar</a>
          <a class='nav-link text-black' href='/auth/login'>Entrar</a>
        </div>
      </div>
    </nav>
    <div class='container mt-4'>
      {{#if flash.success}}
        {{#each flash.success}}
          <div class='alert alert-success'>{{this}}</div>
        {{/each}}
      {{/if}}
      {{#if flash.error}}
        {{#each flash.error}}
          <div class='alert alert-danger'>{{this}}</div>
        {{/each}}
      {{/if}}
      {{{body}}}
    </div>
    <script
      src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js'
    ></script>
  </body>
</html>